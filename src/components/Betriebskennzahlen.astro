---
import SectionWrapper from './shared/SectionWrapper.astro';
---
<SectionWrapper id="betriebskennzahlen" ariaLabelledby="betriebskennzahlen-heading">
  <div class="py-16 md:py-24">
    <h2
      id="betriebskennzahlen-heading"
      class="font-medium mb-4"
      style="font-size: var(--text-2xl); color: var(--color-text-primary);"
    >
      Betriebskennzahlen
    </h2>
    <p style="font-size: var(--text-base); color: var(--color-text-secondary);">
      Messwerte aus dem Pilotbetrieb werden hier nach Abschluss der Pilotphase veroeffentlicht.
    </p>
    <!-- PILOTZAHLEN_EINTRAGEN: Echte Messwerte aus Pilotbetrieb einfuegen, bevor diese Sektion veroeffentlicht wird. Kein Platzhalter-Inhalt verwenden. -->
  </div>
</SectionWrapper>